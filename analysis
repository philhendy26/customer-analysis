# PCA

# Apply PCA to reduce dimensions from 15 to 2

# This allows manifold learning taking more features from a high dimensional structure to a lower dimensional structure but ensuring
#...all features have a representation in this lower structure, hopefully providing the output with a greater understanding of the segmentation

pca = PCA(n_components=2)
df_pca = pca.fit_transform(df_kmeans)

explained_variance = pd.DataFrame([pca.explained_variance_ratio_,      # Extract explained variance per component
                                   pca.explained_variance_ratio_.cumsum()]).T
explained_variance.columns = ['Exp Var', 'Cum Exp Var']
explained_variance          

